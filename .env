# Server URL used by the Android (Capacitor) WebView to reach the Express API.
# Set this to the LAN IP of the machine running the server, e.g.:
#   VITE_APP_URL=https://uni-d.onrender.com
#
# Leave blank (or remove) when running only in a browser — relative paths work fine there.
VITE_APP_URL=https://uni-d.onrender.com/
